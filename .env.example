# Salin file ini menjadi `.env` lalu isi sesuai kebutuhan.
# Variabel dengan prefix VITE_ akan ter-bundle ke kode browser.

# Base URL backend (dibangun di Cursor). Kosongkan untuk pakai mock data.
# Contoh: http://localhost:3000/api  atau  https://verichain-api.example.com
VITE_API_BASE_URL=

# Nama institusi (opsional, untuk tampilan UI)
VITE_APP_NAME=VeriChain
